@page "/seguimiento"
@rendermode InteractiveServer
@using SuplementosApp.Web.Data
@using SuplementosApp.Web.Services.Interfaces
@using System.Text
@using ClosedXML.Excel
@inject ISeguimientoClienteService SeguimientoService
@inject IJSRuntime JS

<PageTitle>Seguimiento de Clientes</PageTitle>

<h1>Seguimiento de Clientes</h1>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Nombre</label>
                <InputText class="form-control" @bind-Value="_filtroNombre" placeholder="Buscar por nombre..." />
            </div>
            <div class="col-md-3">
                <div class="form-check mt-4">
                    <input class="form-check-input" type="checkbox" id="soloSinLlamar" @bind="_filtroSoloSinLlamar" />
                    <label class="form-check-label" for="soloSinLlamar">Solo sin llamar</label>
                </div>
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary me-2" @onclick="Buscar">Buscar</button>
                <button class="btn btn-secondary me-2" @onclick="LimpiarFiltros">Limpiar</button>
            </div>
            <div class="col-md-3 text-end">
                <button class="btn btn-outline-success me-2" @onclick="DescargarExcel" title="Exportar lista filtrada a Excel">
                    ?? Excel
                </button>
                <button class="btn btn-success" @onclick="NuevoCliente">Nuevo cliente</button>
            </div>
        </div>
    </div>
</div>

@if (_cargando)
{
    <p>Cargando...</p>
}
else
{
    <p>Total: @_clientes.Count | Sin llamar: @_clientes.Count(c => !c.LlamadaRealizada)</p>

    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Número</th>
                <th>Producto interés</th>
                <th>Llamada</th>
                <th>Rechazado</th>
                <th>Observación</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var c in _clientes)
        {
            <tr class="@(c.LlamadaRealizada ? "" : "table-warning")">
                <td>@c.Nombre</td>
                <td>@c.Numero</td>
                <td>@c.ProductoInteres</td>
                <td>
                    @if (c.LlamadaRealizada)
                    {
                        <span class="badge bg-success">Sí</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">No</span>
                    }
                </td>
                <td>
                    @if (c.Rechazado)
                    {
                        <span class="badge bg-secondary">Sí</span>
                    }
                </td>
                <td>@c.Observacion</td>
                <td>
                    <button class="btn btn-sm btn-secondary me-1" @onclick="@(() => EditarCliente(c))">Editar</button>
                    @if (!c.LlamadaRealizada)
                    {
                        <button class="btn btn-sm btn-success me-1" @onclick="@(() => MarcarLlamada(c.Id))">Llamado</button>
                    }
                    <button class="btn btn-sm btn-danger" @onclick="@(() => EliminarCliente(c.Id))">Eliminar</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@if (_editando)
{
    <hr />
    <h4>@(_modelo.Id == 0 ? "Nuevo cliente" : "Editar cliente")</h4>

    <EditForm Model="_modelo" OnValidSubmit="GuardarCliente">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="row g-2">
            <div class="col-md-3">
                <label class="form-label">Nombre</label>
                <InputText class="form-control" @bind-Value="_modelo.Nombre" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Número (celular/WA)</label>
                <InputText class="form-control" @bind-Value="_modelo.Numero" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Producto de interés</label>
                <InputText class="form-control" @bind-Value="_modelo.ProductoInteres" />
            </div>
            <div class="col-md-3">
                <div class="form-check mt-4">
                    <InputCheckbox class="form-check-input" @bind-Value="_modelo.LlamadaRealizada" id="llamadaCheck" />
                    <label class="form-check-label" for="llamadaCheck">Llamada realizada</label>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-check mt-4">
                    <InputCheckbox class="form-check-input" @bind-Value="_modelo.Rechazado" id="rechazadoCheck" />
                    <label class="form-check-label text-danger" for="rechazadoCheck">Rechazado</label>
                </div>
            </div>
        </div>
        <div class="mt-2">
            <label class="form-label">Observación</label>
            <InputTextArea class="form-control" @bind-Value="_modelo.Observacion" rows="2" />
        </div>

        <div class="mt-3">
            <button class="btn btn-primary me-2" type="submit">Guardar</button>
            <button class="btn btn-secondary" type="button" @onclick="Cancelar">Cancelar</button>
        </div>
    </EditForm>
}

@code {
    private List<SeguimientoCliente> _clientes = new();

    private bool _cargando = true;
    private bool _editando = false;
    private SeguimientoCliente _modelo = new();

    private string? _filtroNombre;
    private bool _filtroSoloSinLlamar = false;

    protected override async Task OnInitializedAsync() => await CargarClientes();

    private async Task CargarClientes()
    {
        _cargando = true;
        _clientes = (await SeguimientoService.GetAllAsync(
            _filtroSoloSinLlamar ? true : null,
            _filtroNombre)).ToList();
        _cargando = false;
    }

    private async Task Buscar() => await CargarClientes();

    private async Task LimpiarFiltros()
    {
        _filtroNombre = null;
        _filtroSoloSinLlamar = false;
        await CargarClientes();
    }

    private void NuevoCliente()
    {
        _modelo = new SeguimientoCliente { Nombre = "Prospecto" };
        _editando = true;
    }

    private void EditarCliente(SeguimientoCliente c)
    {
        _modelo = new SeguimientoCliente
        {
            Id = c.Id,
            Nombre = c.Nombre,
            Numero = c.Numero,
            ProductoInteres = c.ProductoInteres,
            LlamadaRealizada = c.LlamadaRealizada,
            Rechazado = c.Rechazado,
            Observacion = c.Observacion
        };
        _editando = true;
    }

    private async Task GuardarCliente()
    {
        if (_modelo.Id == 0)
            await SeguimientoService.CreateAsync(_modelo);
        else
            await SeguimientoService.UpdateAsync(_modelo);

        _editando = false;
        await CargarClientes();
    }

    private void Cancelar() => _editando = false;

    private async Task EliminarCliente(int id)
    {
        var ok = await SeguimientoService.DeleteAsync(id);
        if (ok) await CargarClientes();
    }

    private async Task MarcarLlamada(int id)
    {
        var cliente = _clientes.FirstOrDefault(c => c.Id == id);
        if (cliente != null)
        {
            cliente.LlamadaRealizada = true;
            await SeguimientoService.UpdateAsync(cliente);
            await CargarClientes();
        }
    }




    private async Task DescargarExcel()
    {
        using var wb = new XLWorkbook();
        var ws = wb.Worksheets.Add("Seguimiento");

        // Encabezado con estilo
        var headers = new[] { "Nombre", "Número", "Producto de interés", "Llamada realizada", "Rechazado", "Observación" };
        for (int i = 0; i < headers.Length; i++)
        {
            var cell = ws.Cell(1, i + 1);
            cell.Value = headers[i];
            cell.Style.Font.Bold = true;
            cell.Style.Fill.BackgroundColor = XLColor.FromHtml("#4472C4");
            cell.Style.Font.FontColor = XLColor.White;
        }

        // Datos
        for (int i = 0; i < _clientes.Count; i++)
        {
            var c = _clientes[i];
            int row = i + 2;
            ws.Cell(row, 1).Value = c.Nombre ?? "";
            ws.Cell(row, 2).Value = c.Numero ?? "";
            ws.Cell(row, 3).Value = c.ProductoInteres ?? "";
            ws.Cell(row, 4).Value = c.LlamadaRealizada ? "Sí" : "No";
            ws.Cell(row, 5).Value = c.Rechazado ? "Sí" : "No";
            ws.Cell(row, 6).Value = c.Observacion ?? "";
        }

        // AutoFilter real en toda la tabla
        ws.RangeUsed()!.SetAutoFilter();

        // Ajustar ancho de columnas
        ws.Columns().AdjustToContents();

        using var ms = new MemoryStream();
        wb.SaveAs(ms);
        var base64 = Convert.ToBase64String(ms.ToArray());

        var filtro = _filtroSoloSinLlamar ? "_sin_llamar" : "";
        var fileName = $"seguimiento{filtro}_{DateTime.Today:yyyyMMdd}.xlsx";

        await JS.InvokeVoidAsync("downloadFileFromBase64", fileName,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", base64);
    }
}
