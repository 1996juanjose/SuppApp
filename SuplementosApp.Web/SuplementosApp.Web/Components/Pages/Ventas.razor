@page "/ventas"
@rendermode InteractiveServer
@using SuplementosApp.Web.Data
@using SuplementosApp.Web.Services.Interfaces
@inject IVentaService VentaService
@inject IVendedorService VendedorService
@* Catálogos hardcodeados por ahora, no usamos servicios *@
@* @inject IEstadosVentaService EstadosVentaService *@
@* @inject IMetodosEnvioService MetodosEnvioService *@
@* @inject IMetodosPagoService MetodosPagoService *@
@* @inject ICanalesVentaService CanalesVentaService *@

<PageTitle>Ventas</PageTitle>

<h1>Ventas</h1>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-2">
                <label class="form-label">Desde</label>
                <InputDate class="form-control" @bind-Value="_filtroDesde" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Hasta</label>
                <InputDate class="form-control" @bind-Value="_filtroHasta" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Vendedor</label>
                <select class="form-select" @bind="_filtroVendedorId">
                    <option value="">-- Todos --</option>
                    @foreach (var v in _vendedores)
                    {
                        <option value="@v.Id">@v.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Estado</label>
                <select class="form-select" @bind="_filtroEstadoId">
                    <option value="">-- Todos --</option>
                    @foreach (var e in _estadosVenta)
                    {
                        <option value="@e.Id">@e.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Región</label>
                <InputText class="form-control" @bind-Value="_filtroRegion" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Método pago</label>
                <select class="form-select" @bind="_filtroMetodoPagoId">
                    <option value="">-- Todos --</option>
                    @foreach (var m in _metodosPago)
                    {
                        <option value="@m.Id">@m.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Celular</label>
                <InputText class="form-control" @bind-Value="_filtroCelular" />
            </div>
        </div>
        <div class="mt-2">
            <button class="btn btn-primary me-2" @onclick="Buscar">Buscar</button>
            <button class="btn btn-secondary me-2" @onclick="LimpiarFiltros">Limpiar</button>
            <button class="btn btn-success float-end" @onclick="NuevaVenta">Nueva venta</button>
        </div>
    </div>
</div>

@if (_cargando)
{
    <p>Cargando...</p>
}
else
{
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Vendedor</th>
                <th>Estado</th>
                <th>Tipo</th>
                <th>Región</th>
                <th>Precio</th>
                <th>Pagado</th>
                <th>Debe</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var v in _ventas)
        {
            <tr>
                <td>@v.Fecha.ToShortDateString()</td>
                <td>@v.NombreCliente</td>
                <td>@v.Vendedor?.Nombre</td>
                <td>@v.EstadoVenta?.Nombre</td>
                <td>@v.TipoContacto</td>
                <td>@v.Region</td>
                <td>@v.PrecioVenta</td>
                <td>@v.Pagado</td>
                <td>@v.Debe</td>
                <td>
                    <button class="btn btn-sm btn-secondary me-1" @onclick="@(() => EditarVenta(v))">Editar</button>
                    <button class="btn btn-sm btn-success me-1" @onclick="@(() => Pagar(v.Id))" disabled="@(v.Debe <= 0)">Pagar</button>
                    <button class="btn btn-sm btn-danger" @onclick="@(() => EliminarVenta(v.Id))">Eliminar</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@if (_editando)
{
    <hr />
    <h4>@(_ventaModelo.Id == 0 ? "Nueva venta" : "Editar venta")</h4>

    <EditForm Model="_ventaModelo" OnValidSubmit="GuardarVenta">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="row g-2">
            <div class="col-md-3">
                <label class="form-label">Fecha</label>
                <InputDate class="form-control" @bind-Value="_ventaModelo.Fecha" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Cliente</label>
                <InputText class="form-control" @bind-Value="_ventaModelo.NombreCliente" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Región</label>
                <InputText class="form-control" @bind-Value="_ventaModelo.Region" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Celular</label>
                <InputText class="form-control" @bind-Value="_ventaModelo.Celular" />
            </div>
        </div>

        <div class="row g-2 mt-2">
            <div class="col-md-3">
                <label class="form-label">Tipo contacto</label>
                <select class="form-select" @bind="_ventaModelo.TipoContacto">
                    <option value="Lead">Lead</option>
                    <option value="Facebook">Facebook</option>
                    <option value="Por referido">Por referido</option>
                    <option value="WhatsApp org\u00e1nico">WhatsApp org\u00e1nico</option>
                    <option value="Directo">Directo</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">DNI</label>
                <InputText class="form-control" @bind-Value="_ventaModelo.DNI" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Vendedor</label>
                <select class="form-select" @bind="_ventaModelo.VendedorId">
                    <option value="">-- Seleccione --</option>
                    @foreach (var v in _vendedores)
                    {
                        <option value="@v.Id">@v.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Estado</label>
                <select class="form-select" @bind="_ventaModelo.EstadoVentaId">
                    <option value="">-- Seleccione --</option>
                    @foreach (var e in _estadosVenta)
                    {
                        <option value="@e.Id">@e.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Productos</label>
                <InputText class="form-control" @bind-Value="_ventaModelo.Productos" />
            </div>
        </div>

        <div class="row g-2 mt-2">
            <div class="col-md-3">
                <label class="form-label">Método envío</label>
                <select class="form-select" @bind="_ventaModelo.MetodoEnvioId">
                    <option value="">-- Seleccione --</option>
                    @foreach (var m in _metodosEnvio)
                    {
                        <option value="@m.Id">@m.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Método pago</label>
                <select class="form-select" @bind="_ventaModelo.MetodoPagoId">
                    <option value="">-- Seleccione --</option>
                    @foreach (var m in _metodosPago)
                    {
                        <option value="@m.Id">@m.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Canal venta</label>
                <select class="form-select" @bind="_ventaModelo.CanalVentaId">
                    <option value="">-- Seleccione --</option>
                    @foreach (var c in _canalesVenta)
                    {
                        <option value="@c.Id">@c.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Costo envío</label>
                <InputNumber class="form-control" @bind-Value="_ventaModelo.CostoEnvio" />
            </div>
        </div>

        <div class="row g-2 mt-2">
            <div class="col-md-3">
                <label class="form-label">Precio venta</label>
                <InputNumber class="form-control" @bind-Value="_ventaModelo.PrecioVenta" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Pagado</label>
                <InputNumber class="form-control" @bind-Value="_ventaModelo.Pagado" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Debe (auto)</label>
                <input class="form-control" value="@_ventaModelo.Debe" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label">Comisión</label>
                <InputNumber class="form-control" @bind-Value="_ventaModelo.Comision" />
            </div>
        </div>

        <div class="mt-2">
            <label class="form-label">Observación</label>
            <InputTextArea class="form-control" @bind-Value="_ventaModelo.Observacion" />
        </div>

        <div class="mt-3">
            <button class="btn btn-primary me-2" type="submit">Guardar</button>
            <button class="btn btn-secondary" type="button" @onclick="CancelarEdicionVenta">Cancelar</button>
        </div>
    </EditForm>
}

@code {
    private List<Venta> _ventas = new();
    private List<Vendedor> _vendedores = new();
    private List<EstadoVenta> _estadosVenta = new();
    private List<MetodoEnvio> _metodosEnvio = new();
    private List<MetodoPago> _metodosPago = new();
    private List<CanalVenta> _canalesVenta = new();

    private bool _cargando = true;
    private bool _editando = false;
    private Venta _ventaModelo = new();

    private DateTime? _filtroDesde;
    private DateTime? _filtroHasta;
    private string? _filtroVendedorId;
    private string? _filtroEstadoId;
    private string? _filtroRegion;
    private int? _filtroMetodoPagoId;
    private string? _filtroCelular;

    protected override async Task OnInitializedAsync()
    {
        await CargarCatalogos();
        await CargarVentas();
    }

    private async Task CargarCatalogos()
    {
        // Vendedores desde BD
        _vendedores = (await VendedorService.GetAllAsync(true)).ToList();

        // Estados de la venta (hardcode)
        _estadosVenta = new List<EstadoVenta>
        {
            new() { Id = 1, Nombre = "COMPROBANTE PROVINCIA" },
            new() { Id = 2, Nombre = "En destino" },
            new() { Id = 3, Nombre = "Entregado" },
            new() { Id = 4, Nombre = "Enviado" },
            new() { Id = 5, Nombre = "Lima embalado" },
            new() { Id = 6, Nombre = "Por enviar provincia" },
            new() { Id = 7, Nombre = "Cancelado/No quiere" }
        };

        // Métodos de envío (hardcode)
        _metodosEnvio = new List<MetodoEnvio>
        {
            new() { Id = 1, Nombre = "Shalom" },
            new() { Id = 2, Nombre = "Olva Courier" }
        };

        // Métodos de pago (hardcode)
        _metodosPago = new List<MetodoPago>
        {
            new() { Id = 1, Nombre = "Yape" },
            new() { Id = 2, Nombre = "BCP" },
            new() { Id = 3, Nombre = "Efectivo" },
            new() { Id = 4, Nombre = "Plin" },
            new() { Id = 5, Nombre = "Mercado Pago" }
        };

        // Canales de venta (hardcode)
        _canalesVenta = new List<CanalVenta>
        {
            new() { Id = 1, Nombre = "Orgánico" },
            new() { Id = 2, Nombre = "Shopify" },
            new() { Id = 3, Nombre = "WhatsApp" }
        };
    }

    private async Task CargarVentas()
    {
        _cargando = true;

        int? vendedorId = string.IsNullOrWhiteSpace(_filtroVendedorId) ? null : int.Parse(_filtroVendedorId);
        int? estadoId = string.IsNullOrWhiteSpace(_filtroEstadoId) ? null : int.Parse(_filtroEstadoId);

        _ventas = (await VentaService.GetAllAsync(
            _filtroDesde,
            _filtroHasta,
            vendedorId,
            estadoId,
            _filtroRegion,
            _filtroMetodoPagoId,
            _filtroCelular)).ToList();

        _cargando = false;
    }

    private async Task Buscar() => await CargarVentas();

    private async Task LimpiarFiltros()
    {
        _filtroDesde = null;
        _filtroHasta = null;
        _filtroVendedorId = null;
        _filtroEstadoId = null;
        _filtroRegion = null;
        _filtroMetodoPagoId = null;
        _filtroCelular = null;
        await CargarVentas();
    }

    private void NuevaVenta()
    {
        _ventaModelo = new Venta
        {
            Fecha = DateTime.Now,
            EstadoVentaId = 2,   // En destino
            CanalVentaId = 3,    // WhatsApp
            MetodoPagoId = 1,    // Yape
            MetodoEnvioId = 2,   // Olva Courier
            Region = "Lima",
            TipoContacto = "Lead"
        };
        _editando = true;
    }

    private void EditarVenta(Venta venta)
    {
        _ventaModelo = new Venta
        {
            Id = venta.Id,
            Fecha = venta.Fecha,
            NombreCliente = venta.NombreCliente,
            Region = venta.Region,
            DireccionEnvio = venta.DireccionEnvio,
            Celular = venta.Celular,
            DNI = venta.DNI,
            EstadoVentaId = venta.EstadoVentaId,
            Observacion = venta.Observacion,
            NroOrden = venta.NroOrden,
            Cod = venta.Cod,
            Clave = venta.Clave,
            CostoEnvio = venta.CostoEnvio,
            Productos = venta.Productos,
            MetodoEnvioId = venta.MetodoEnvioId,
            MetodoPagoId = venta.MetodoPagoId,
            CanalVentaId = venta.CanalVentaId,
            PrecioVenta = venta.PrecioVenta,
            Pagado = venta.Pagado,
            VendedorId = venta.VendedorId,
            Comision = venta.Comision,
            TipoContacto = venta.TipoContacto
        };
        _editando = true;
    }

    private async Task GuardarVenta()
    {
        if (_ventaModelo.Id == 0)
        {
            await VentaService.CreateAsync(_ventaModelo);
        }
        else
        {
            await VentaService.UpdateAsync(_ventaModelo);
        }

        _editando = false;
        await CargarVentas();
    }

    private void CancelarEdicionVenta()
    {
        _editando = false;
    }

    private async Task Pagar(int id)
    {
        var ok = await VentaService.PagarAsync(id);
        if (ok)
        {
            await CargarVentas();
        }
    }

    private async Task EliminarVenta(int id)
    {
        var ok = await VentaService.DeleteAsync(id);
        if (ok)
        {
            await CargarVentas();
        }
    }
}
