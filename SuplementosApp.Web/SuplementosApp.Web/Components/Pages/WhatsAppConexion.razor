@page "/whatsapp"
@rendermode InteractiveServer
@using SuplementosApp.Web.Services
@inject EvolutionApiService EvolutionService
@inject IConfiguration Config
@implements IDisposable

<PageTitle>WhatsApp Business</PageTitle>

<h1>WhatsApp Business</h1>

<div class="row justify-content-center">
    <div class="col-md-6">

        @* Estado de conexion *@
        <div class="card mb-4">
            <div class="card-body text-center">
                @if (_estado == "open")
                {
                    <div class="text-success fs-5 fw-bold">
                        &#x2705; WhatsApp conectado
                    </div>
                    <p class="text-muted mt-1 mb-3">Tu numero <strong>+51 940 974 915</strong> esta vinculado correctamente.</p>
                    <button class="btn btn-outline-danger btn-sm" @onclick="Desconectar" disabled="@_cargando">
                        Desconectar
                    </button>
                }
                else if (_estado == "connecting")
                {
                    <div class="text-warning fs-5 fw-bold">
                        &#x23F3; Conectando...
                    </div>
                    <p class="text-muted mt-1">Escanea el QR con tu WhatsApp Business.</p>
                }
                else
                {
                    <div class="text-danger fs-5 fw-bold">
                        &#x274C; WhatsApp desconectado
                    </div>
                    <p class="text-muted mt-1">Escanea el codigo QR para vincular tu numero.</p>
                }
            </div>
        </div>

        @* QR Code *@
        @if (_estado != "open")
        {
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-bold">Escanear con WhatsApp Business</span>
                    <button class="btn btn-outline-primary btn-sm" @onclick="RefrescarQr" disabled="@_cargando">
                        @if (_cargando)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Refrescar QR
                    </button>
                </div>
                <div class="card-body text-center py-4">
                    @if (_cargando && _qrBase64 == null)
                    {
                        <div class="my-4">
                            <div class="spinner-border text-success" role="status"></div>
                            <p class="mt-2 text-muted">Generando codigo QR... (puede tardar ~15 segundos)</p>
                        </div>
                    }
                    else if (_qrBase64 != null)
                    {
                        <img src="@_qrBase64" alt="QR WhatsApp" class="img-fluid" style="max-width:280px;" />
                        <p class="mt-3 text-muted small">
                            El QR expira en ~60 segundos.<br />
                            Abre WhatsApp Business &rarr; <strong>Dispositivos vinculados</strong> &rarr; <strong>Vincular dispositivo</strong>
                        </p>
                    }
                    else if (_errorMensaje != null)
                    {
                        <div class="alert alert-warning">
                            <strong>No se pudo obtener el QR automaticamente.</strong><br />
                            Puedes escanearlo directamente desde el Manager:
                        </div>
                        <a href="@_managerUrl" target="_blank" class="btn btn-success mt-1 me-2">
                            Abrir Evolution Manager
                        </a>
                        <button class="btn btn-primary mt-1" @onclick="RefrescarQr">Reintentar</button>
                    }
                </div>
            </div>

            <p class="text-muted text-center small mt-2">
                La pagina verifica el estado automaticamente cada 10 segundos.
            </p>
        }

        @* Webhook Evolution API *@
        <div class="card mt-4">
            <div class="card-header fw-bold">Webhook para captura de prospectos</div>
            <div class="card-body">
                @if (_webhookUrl != null)
                {
                    <p class="mb-1 text-muted small">URL actualmente registrada en Evolution API:</p>
                    <code class="d-block mb-3 text-break">@_webhookUrl</code>
                    @if (_webhookUrl == _webhookUrlEditable)
                    {
                        <div class="alert alert-success py-2 mb-3">&#x2705; Webhook configurado correctamente.</div>
                    }
                    else
                    {
                        <div class="alert alert-warning py-2 mb-3">&#x26A0;&#xFE0F; La URL registrada no coincide con la que vas a enviar.</div>
                    }
                }
                else
                {
                    <div class="alert alert-secondary py-2 mb-3">No hay webhook configurado aun.</div>
                }

                <label class="form-label fw-semibold">
                    URL del webhook <span class="text-muted fw-normal">(pega tu URL de ngrok aqui)</span>
                </label>
                <div class="input-group mb-3">
                    <input type="text"
                           class="form-control font-monospace"
                           @bind="_webhookUrlEditable"
                           @bind:event="oninput"
                           placeholder="https://xxxx-xx-xx.ngrok-free.app/api/prospecto/evolution" />
                    <button class="btn btn-outline-secondary" type="button"
                            @onclick="ResetearUrl" title="Restaurar URL de config">
                        &#x21BA;
                    </button>
                </div>

                <button class="btn btn-primary btn-sm"
                        @onclick="RegistrarWebhook"
                        disabled="@(_guardandoWebhook || string.IsNullOrWhiteSpace(_webhookUrlEditable))">
                    @if (_guardandoWebhook)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Registrar en Evolution API
                </button>

                @if (_mensajeWebhook != null)
                {
                    <div class="alert @(_webhookOk ? "alert-success" : "alert-danger") py-2 mt-3 mb-0">
                        @_mensajeWebhook
                    </div>
                }
            </div>
        </div>

    </div>
</div>

@code {
    private string _estado = "close";
    private string? _qrBase64;
    private string? _errorMensaje;
    private bool _cargando = false;
    private System.Threading.Timer? _timer;

    private string? _webhookUrl;
    private string _webhookUrlEditable = string.Empty;
    private bool _guardandoWebhook = false;
    private string? _mensajeWebhook;
    private bool _webhookOk = false;
    private string _managerUrl = "https://ventas-evolution-api.wv6a0u.easypanel.host/manager";

    private string _webhookEndpoint =>
        $"{Config["App:PublicUrl"]?.TrimEnd('/')}/api/prospecto/evolution";

    protected override async Task OnInitializedAsync()
    {
        await VerificarEstado();
        _webhookUrl = await EvolutionService.ObtenerWebhookUrlAsync();
        _webhookUrlEditable = _webhookEndpoint;

        _timer = new System.Threading.Timer(async _ =>
        {
            await VerificarEstado();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private async Task VerificarEstado()
    {
        var nuevoEstado = await EvolutionService.ObtenerEstadoAsync();

        if (nuevoEstado != _estado)
        {
            _estado = nuevoEstado;
            if (_estado == "open")
                _qrBase64 = null;
        }

        if (_estado != "open" && _qrBase64 == null && !_cargando)
            await CargarQr();
    }

    private async Task CargarQr()
    {
        _cargando = true;
        _errorMensaje = null;

        var qr = await EvolutionService.ObtenerQrAsync();

        if (qr != null)
            _qrBase64 = qr;
        else
            _errorMensaje = "No se pudo obtener el QR. Verifica la conexion con Evolution API.";

        _cargando = false;
    }

    private async Task RefrescarQr()
    {
        _qrBase64 = null;
        await CargarQr();
    }

    private async Task Desconectar()
    {
        _cargando = true;
        await EvolutionService.DesconectarAsync();
        _estado = "close";
        _qrBase64 = null;
        _cargando = false;
        await CargarQr();
    }

    private async Task RegistrarWebhook()
    {
        _guardandoWebhook = true;
        _mensajeWebhook = null;

        var ok = await EvolutionService.ConfigurarWebhookAsync(_webhookUrlEditable);
        if (ok)
        {
            _webhookOk = true;
            _mensajeWebhook = "Webhook registrado correctamente.";
            _webhookUrl = await EvolutionService.ObtenerWebhookUrlAsync();
        }
        else
        {
            _webhookOk = false;
            _mensajeWebhook = "Error al registrar el webhook. Verifica que la URL sea accesible desde internet.";
        }

        _guardandoWebhook = false;
    }

    private void ResetearUrl() => _webhookUrlEditable = _webhookEndpoint;

    public void Dispose() => _timer?.Dispose();
}
