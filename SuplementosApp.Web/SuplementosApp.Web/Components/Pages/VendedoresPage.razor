@page "/vendedores"
@rendermode InteractiveServer
@using SuplementosApp.Web.Data
@using SuplementosApp.Web.Services.Interfaces
@inject IVendedorService VendedorService

<PageTitle>Vendedores</PageTitle>

<h1>Vendedores</h1>

@if (_cargando)
{
    <p>Cargando...</p>
}
else
{
    <button class="btn btn-primary mb-2" @onclick="Nuevo">Nuevo vendedor</button>

    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Email</th>
                <th>Comisión base</th>
                <th>Fecha ingreso</th>
                <th>Activo</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var v in _vendedores)
        {
            <tr>
                <td>@v.Nombre</td>
                <td>@v.Email</td>
                <td>@v.ComisionBase</td>
                <td>@v.FechaIngreso?.ToShortDateString()</td>
                <td>@(v.Activo ? "Sí" : "No")</td>
                <td>
                    <button class="btn btn-sm btn-secondary me-1" @onclick="@(() => Editar(v))">Editar</button>
                    <button class="btn btn-sm btn-danger" @onclick="@(() => Eliminar(v.Id))">Eliminar</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@if (_editando)
{
    <hr />
    <h4>@(_modelo.Id == 0 ? "Nuevo vendedor" : "Editar vendedor")</h4>

    <EditForm Model="_modelo" OnValidSubmit="Guardar">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-2">
            <label class="form-label">Nombre</label>
            <InputText class="form-control" @bind-Value="_modelo.Nombre" />
        </div>

        <div class="mb-2">
            <label class="form-label">Email</label>
            <InputText class="form-control" @bind-Value="_modelo.Email" />
        </div>

        <div class="mb-2">
            <label class="form-label">Comisión base</label>
            <InputNumber class="form-control" @bind-Value="_modelo.ComisionBase" />
        </div>

        <div class="mb-2">
            <label class="form-label">Fecha ingreso</label>
            <InputDate class="form-control" @bind-Value="_modelo.FechaIngreso" />
        </div>

        <div class="form-check mb-2">
            <InputCheckbox class="form-check-input" @bind-Value="_modelo.Activo" />
            <label class="form-check-label">Activo</label>
        </div>

        <div class="mb-2">
            <label class="form-label">Observación</label>
            <InputTextArea class="form-control" @bind-Value="_modelo.Observacion" />
        </div>

        <button class="btn btn-primary me-2" type="submit">Guardar</button>
        <button class="btn btn-secondary" type="button" @onclick="CancelarEdicion">Cancelar</button>
    </EditForm>
}

@code {
    private List<Vendedor> _vendedores = new();
    private Vendedor _modelo = new();
    private bool _cargando = true;
    private bool _editando = false;

    protected override async Task OnInitializedAsync()
    {
        _vendedores = (await VendedorService.GetAllAsync()).ToList();
        _cargando = false;
    }

    private void Nuevo()
    {
        _modelo = new Vendedor
        {
            Activo = true,
            FechaIngreso = DateTime.Now
        };
        _editando = true;
    }

    private void Editar(Vendedor vendedor)
    {
        _modelo = new Vendedor
        {
            Id = vendedor.Id,
            Nombre = vendedor.Nombre,
            Email = vendedor.Email,
            ComisionBase = vendedor.ComisionBase,
            FechaIngreso = vendedor.FechaIngreso,
            Activo = vendedor.Activo,
            Observacion = vendedor.Observacion
        };
        _editando = true;
    }

    private async Task Guardar()
    {
        if (_modelo.Id == 0)
        {
            await VendedorService.CreateAsync(_modelo);
        }
        else
        {
            await VendedorService.UpdateAsync(_modelo);
        }

        _editando = false;
        _vendedores = (await VendedorService.GetAllAsync()).ToList();
    }

    private void CancelarEdicion()
    {
        _editando = false;
    }

    private async Task Eliminar(int id)
    {
        var ok = await VendedorService.DeleteAsync(id);
        if (ok)
        {
            _vendedores = (await VendedorService.GetAllAsync()).ToList();
        }
    }
}
