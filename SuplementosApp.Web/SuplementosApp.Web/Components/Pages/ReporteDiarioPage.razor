@page "/reporte-diario"
@rendermode InteractiveServer
@using SuplementosApp.Web.Data
@using SuplementosApp.Web.Services.Interfaces
@inject IReporteDiarioService ReporteDiarioService
@inject IVendedorService VendedorService
@inject IVentaService VentaService

<PageTitle>Reporte Diario</PageTitle>

<h1>Reporte Diario</h1>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label">Desde</label>
                <InputDate class="form-control" @bind-Value="_filtroDesde" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Hasta</label>
                <InputDate class="form-control" @bind-Value="_filtroHasta" />
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary me-2" @onclick="Buscar">Buscar</button>
                <button class="btn btn-secondary me-2" @onclick="LimpiarFiltros">Limpiar</button>
            </div>
            <div class="col-md-3 text-end">
                <button class="btn btn-success" @onclick="NuevoReporte">Nuevo reporte</button>
            </div>
        </div>
    </div>
</div>

@if (_cargando)
{
    <p>Cargando...</p>
}
else
{
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Gasto FB</th>
                <th>Mensajes</th>
                <th>Pedidos</th>
                <th>Facturación</th>
                <th>ROAS</th>
                <th>Tasa Cierre</th>
                <th>CPA</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var r in _reportes)
        {
            <tr>
                <td>@r.Fecha.ToShortDateString()</td>
                <td>@r.GastoPublicidadFB.ToString("N2")</td>
                <td>@r.TotalMensajes</td>
                <td>@r.TotalPedidos</td>
                <td>@r.FacturacionTotal.ToString("N2")</td>
                <td>@r.ROAS.ToString("N2")</td>
                <td>@((r.TasaCierre * 100).ToString("N1"))%</td>
                <td>@r.CPA.ToString("N2")</td>
                <td>
                    <button class="btn btn-sm btn-secondary me-1" @onclick="@(() => EditarReporte(r))">Editar</button>
                    <button class="btn btn-sm btn-danger" @onclick="@(() => EliminarReporte(r.Id))">Eliminar</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@if (_editando)
{
    <hr />
    <h4>@(_modelo.Id == 0 ? "Nuevo reporte" : $"Editar reporte {_modelo.Fecha.ToShortDateString()}")</h4>

    <EditForm Model="_modelo" OnValidSubmit="GuardarReporte">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="row g-2">
            <div class="col-md-2">
                <label class="form-label">Fecha</label>
                <InputDate class="form-control" @bind-Value="_modelo.Fecha" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Gasto FB <span class="text-muted">(manual)</span></label>
                <InputNumber class="form-control" @bind-Value="_modelo.GastoPublicidadFB" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Total mensajes <span class="text-muted">(manual)</span></label>
                <InputNumber class="form-control" @bind-Value="_modelo.TotalMensajes" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Total pedidos</label>
                <InputNumber class="form-control" @bind-Value="_modelo.TotalPedidos" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Facturación total</label>
                <InputNumber class="form-control" @bind-Value="_modelo.FacturacionTotal" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="button" class="btn btn-outline-primary w-100" @onclick="AutoCalcularDesdeVentas"
                        title="Carga pedidos, facturación y detalle por vendedor desde las ventas de tipo Lead del día">
                    ? Cargar desde ventas
                </button>
            </div>
        </div>

        <div class="row g-2 mt-1">
            <div class="col-md-2">
                <label class="form-label">ROAS (auto)</label>
                <input class="form-control" value="@(_modelo.GastoPublicidadFB > 0 ? (_modelo.FacturacionTotal / _modelo.GastoPublicidadFB).ToString("N2") : "0")" readonly />
            </div>
            <div class="col-md-2">
                <label class="form-label">Costo/Mensaje (auto)</label>
                <input class="form-control" value="@(_modelo.TotalMensajes > 0 ? (_modelo.GastoPublicidadFB / _modelo.TotalMensajes).ToString("N2") : "0")" readonly />
            </div>
            <div class="col-md-2">
                <label class="form-label">Tasa Cierre (auto)</label>
                <input class="form-control" value="@(_modelo.TotalMensajes > 0 ? ((_modelo.TotalPedidos * 100m) / _modelo.TotalMensajes).ToString("N1") + "%" : "0%")" readonly />
            </div>
            <div class="col-md-2">
                <label class="form-label">AOV</label>
                <InputNumber class="form-control" @bind-Value="_modelo.AOV" />
            </div>
            <div class="col-md-2">
                <label class="form-label">CPA</label>
                <InputNumber class="form-control" @bind-Value="_modelo.CPA" />
            </div>
        </div>

        <div class="row mt-2">
            <div class="col-md-6">
                <label class="form-label">Observación</label>
                <InputTextArea class="form-control" @bind-Value="_modelo.Observacion" rows="2" />
            </div>
        </div>

        <hr class="mt-3" />
        <h5>Detalle por vendedor
            <small class="text-muted fs-6 ms-2">Puedes usar ? Cargar desde ventas para auto-completar</small>
        </h5>

        <table class="table table-sm table-bordered">
            <thead>
                <tr>
                    <th>Vendedor</th>
                    <th>Facturado</th>
                    <th>Publicidad</th>
                    <th>Mensajes</th>
                    <th>Pedidos</th>
                    <th>Tasa Cierre</th>
                    <th>Observación</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var d in _detalles)
            {
                <tr>
                    <td>
                        <select class="form-select form-select-sm" @bind="d.VendedorId">
                            <option value="0">-- Seleccione --</option>
                            @foreach (var v in _vendedores)
                            {
                                <option value="@v.Id">@v.Nombre</option>
                            }
                        </select>
                    </td>
                    <td><InputNumber class="form-control form-control-sm" @bind-Value="d.Facturado" /></td>
                    <td><InputNumber class="form-control form-control-sm" @bind-Value="d.Publicidad" /></td>
                    <td><InputNumber class="form-control form-control-sm" @bind-Value="d.Mensajes" /></td>
                    <td><InputNumber class="form-control form-control-sm" @bind-Value="d.Pedidos" /></td>
                    <td>
                        <input class="form-control form-control-sm" readonly
                               value="@(d.Mensajes > 0 ? ((d.Pedidos * 100m) / d.Mensajes).ToString("N1") + "%" : "0%")" />
                    </td>
                    <td><InputText class="form-control form-control-sm" @bind-Value="d.Observacion" /></td>
                    <td>
                        <button type="button" class="btn btn-sm btn-danger" @onclick="@(() => QuitarDetalle(d))">X</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>

        <button type="button" class="btn btn-outline-secondary btn-sm mb-3" @onclick="AgregarDetalle">+ Agregar vendedor</button>

        <div class="mt-2">
            <button class="btn btn-primary me-2" type="submit">Guardar</button>
            <button class="btn btn-secondary" type="button" @onclick="Cancelar">Cancelar</button>
        </div>
    </EditForm>
}

@code {
    private List<Data.ReporteDiario> _reportes = new();
    private List<Vendedor> _vendedores = new();
    private List<ReporteDiarioDetalle> _detalles = new();

    private bool _cargando = true;
    private bool _editando = false;
    private Data.ReporteDiario _modelo = new();

    private DateTime? _filtroDesde;
    private DateTime? _filtroHasta;

    protected override async Task OnInitializedAsync()
    {
        _vendedores = (await VendedorService.GetAllAsync(true)).ToList();
        await CargarReportes();
    }

    private async Task CargarReportes()
    {
        _cargando = true;
        _reportes = (await ReporteDiarioService.GetAllAsync(_filtroDesde, _filtroHasta)).ToList();
        _cargando = false;
    }

    private async Task Buscar() => await CargarReportes();

    private async Task LimpiarFiltros()
    {
        _filtroDesde = null;
        _filtroHasta = null;
        await CargarReportes();
    }

    private void NuevoReporte()
    {
        _modelo = new Data.ReporteDiario { Fecha = DateTime.Today };
        _detalles = new List<ReporteDiarioDetalle>();
        _editando = true;
    }

    private void EditarReporte(Data.ReporteDiario r)
    {
        _modelo = new Data.ReporteDiario
        {
            Id = r.Id,
            Fecha = r.Fecha,
            GastoPublicidadFB = r.GastoPublicidadFB,
            TotalMensajes = r.TotalMensajes,
            TotalPedidos = r.TotalPedidos,
            FacturacionTotal = r.FacturacionTotal,
            ROAS = r.ROAS,
            AOV = r.AOV,
            CPA = r.CPA,
            TasaCierre = r.TasaCierre,
            Observacion = r.Observacion
        };
        _detalles = r.Detalles.Select(d => new ReporteDiarioDetalle
        {
            Id = d.Id,
            VendedorId = d.VendedorId,
            Facturado = d.Facturado,
            Publicidad = d.Publicidad,
            Mensajes = d.Mensajes,
            Pedidos = d.Pedidos,
            TasaCierre = d.TasaCierre,
            Observacion = d.Observacion
        }).ToList();
        _editando = true;
    }

    private void AgregarDetalle() => _detalles.Add(new ReporteDiarioDetalle());

    private void QuitarDetalle(ReporteDiarioDetalle d) => _detalles.Remove(d);

    private async Task AutoCalcularDesdeVentas()
    {        
        var ventasDelDia = (await VentaService.GetAllAsync(
            _modelo.Fecha.Date,
            _modelo.Fecha.Date.AddDays(1).AddSeconds(-1)))
            .Where(v => v.TipoContacto == "Lead")
            .ToList();

        // Auto-calcular totales (pedidos y facturación)
        _modelo.TotalPedidos = ventasDelDia.Count;
        _modelo.FacturacionTotal = ventasDelDia.Sum(v => v.PrecioVenta);

        // Auto-calcular detalle por vendedor
        _detalles = ventasDelDia
            .GroupBy(v => v.VendedorId)
            .Select(g => new ReporteDiarioDetalle
            {
                VendedorId = g.Key,
                Pedidos = g.Count(),
                Mensajes = g.Count(), // cada lead = 1 mensaje (mínimo)
                Facturado = g.Sum(v => v.PrecioVenta),
                Publicidad = 0
            })
            .ToList();
    }

    private async Task GuardarReporte()
    {
        await ReporteDiarioService.CreateOrUpdateAsync(_modelo, _detalles);
        _editando = false;
        await CargarReportes();
    }

    private void Cancelar() => _editando = false;

    private async Task EliminarReporte(int id)
    {
        var ok = await ReporteDiarioService.DeleteAsync(id);
        if (ok) await CargarReportes();
    }
}
