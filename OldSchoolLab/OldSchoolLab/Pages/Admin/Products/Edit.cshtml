@page "{id:int?}"
@model OldSchoolLab.Pages.Admin.Products.EditModel
@{
    ViewData["Title"] = Model.Input.Id == 0 ? "Nuevo producto" : "Editar producto";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">@ViewData["Title"]</h1>
    <a asp-page="Index" class="btn btn-outline-secondary">Volver</a>
</div>

<form method="post" class="card shadow-sm">
    <input asp-for="Input.Id" type="hidden" />
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <label asp-for="Input.Name" class="form-label"></label>
                <input asp-for="Input.Name" class="form-control" />
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <div class="form-check mb-2">
                    <input asp-for="Input.IsActive" class="form-check-input" />
                    <label asp-for="Input.IsActive" class="form-check-label"></label>
                </div>
            </div>
        </div>

        <h5 class="mb-3">Precios por cantidad</h5>
        <p class="text-muted small">Cada fila define cuánto cuesta comprar N unidades del producto.</p>

        <table class="table table-bordered align-middle" id="pricesTable">
            <thead class="table-light">
                <tr>
                    <th style="width:150px">Cantidad</th>
                    <th style="width:200px">Precio (S/)</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="pricesBody">
                @for (int i = 0; i < Model.Input.Prices.Count; i++)
                {
                    <tr>
                        <input type="hidden" name="Input.Prices[@i].Id" value="@Model.Input.Prices[i].Id" />
                        <input type="hidden" name="Input.Prices[@i].Delete" value="false" class="deleteFlag" />
                        <td>
                            <input type="number" name="Input.Prices[@i].Quantity"
                                   value="@Model.Input.Prices[i].Quantity"
                                   class="form-control" min="1" max="999" required />
                        </td>
                        <td>
                            <input type="number" name="Input.Prices[@i].Price"
                                   value="@Model.Input.Prices[i].Price"
                                   class="form-control" min="0" step="0.01" required />
                        </td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-danger btn-remove-row">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <button type="button" class="btn btn-outline-secondary btn-sm" id="btnAddRow">+ Agregar precio</button>
    </div>
    <div class="card-footer d-flex justify-content-end gap-2">
        <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
        <button type="submit" class="btn btn-primary">Guardar</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let rowIndex = @Model.Input.Prices.Count;

        document.getElementById('btnAddRow').addEventListener('click', () => {
            const tbody = document.getElementById('pricesBody');
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <input type="hidden" name="Input.Prices[${rowIndex}].Delete" value="false" class="deleteFlag" />
                <td><input type="number" name="Input.Prices[${rowIndex}].Quantity" class="form-control" min="1" max="999" required /></td>
                <td><input type="number" name="Input.Prices[${rowIndex}].Price" class="form-control" min="0" step="0.01" required /></td>
                <td><button type="button" class="btn btn-sm btn-outline-danger btn-remove-row">Eliminar</button></td>
            `;
            tbody.appendChild(tr);
            rowIndex++;
        });

        document.getElementById('pricesBody').addEventListener('click', (e) => {
            if (e.target.classList.contains('btn-remove-row')) {
                const row = e.target.closest('tr');
                const deleteFlag = row.querySelector('.deleteFlag');
                if (deleteFlag) {
                    deleteFlag.value = 'true';
                    row.style.display = 'none';
                } else {
                    row.remove();
                }
            }
        });
    </script>
}
