@page
@model OldSchoolLab.Pages.Admin.AuditLog.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "AuditorĒa";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">AuditorĒa</h1>
</div>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-3">
        <label class="form-label">Tabla</label>
        <select name="table" class="form-select">
            <option value="">Todas</option>
            <option value="Registro" selected="@(Model.FilterTable == "Registro")">Registros</option>
            <option value="Producto" selected="@(Model.FilterTable == "Producto")">Productos</option>
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label">Usuario</label>
        <input name="user" class="form-control" value="@Model.FilterUser" placeholder="Nombre de usuario" />
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-outline-primary w-100">Filtrar</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-sm table-bordered table-striped align-middle">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Tabla</th>
                <th>ID</th>
                <th>Acci¾n</th>
                <th>Usuario</th>
                <th>Fecha y hora</th>
                <th>Cambios</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Logs.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">Sin registros de auditorĒa.</td>
                </tr>
            }
            @foreach (var log in Model.Logs)
            {
                <tr>
                    <td>@log.Id</td>
                    <td>
                        <span class="badge text-bg-@(log.TableName == "Registro" ? "primary" : "secondary")">
                            @log.TableName
                        </span>
                    </td>
                    <td>@log.RecordId</td>
                    <td>
                        <span class="badge text-bg-@(log.Action == "Creado" ? "success" : "warning")">
                            @log.Action
                        </span>
                    </td>
                    <td>@log.ChangedByUserName</td>
                    <td class="text-nowrap">@log.ChangedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>
                        @if (!string.IsNullOrEmpty(log.Details))
                        {
                            <details>
                                <summary class="text-primary" style="cursor:pointer">Ver detalle</summary>
                                <pre class="mt-1 p-2 bg-light rounded small" style="max-width:400px;overflow-x:auto;white-space:pre-wrap">@FormatJson(log.Details)</pre>
                            </details>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<p class="text-muted small">Mostrando ·ltimos 300 registros.</p>

@functions {
    static string FormatJson(string json)
    {
        try
        {
            var doc = JsonDocument.Parse(json);
            return JsonSerializer.Serialize(doc, new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return json;
        }
    }
}
