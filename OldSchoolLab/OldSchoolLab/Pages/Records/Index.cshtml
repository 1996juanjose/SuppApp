@page
@model OldSchoolLab.Pages.Records.IndexModel
@{
    ViewData["Title"] = "Registros";
    int totalCols = 13 + (Model.CanEdit ? 1 : 0) + (Model.CanViewAudit ? 1 : 0);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-0">Registros</h1>
        <p class="text-muted mb-0">Mantenimiento del Excel en web.</p>
    </div>
    @if (Model.CanEdit)
    {
        <a asp-page="/Records/Create" class="btn btn-primary">Nuevo registro</a>
    }
</div>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-4">
        <label class="form-label">Estado</label>
        <select asp-for="StatusId" class="form-select">
            <option value="">Todos</option>
            @foreach (var status in Model.Statuses)
            {
                <option value="@status.Id">@status.Name</option>
            }
        </select>
    </div>
    <div class="col-md-6">
        <label asp-for="Search" class="form-label">Buscar</label>
        <input asp-for="Search" class="form-control" placeholder="Celular, nombre, DNI o actividad" />
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-outline-primary w-100">Filtrar</button>
    </div>
</form>

@if (TempData["StatusMessage"] is string message)
{
    <div class="alert alert-success">@message</div>
}

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Estado</th>
                <th>Fecha</th>
                <th>Celular</th>
                <th>Nombre / Ref WA</th>
                <th>Actividad de la llamada</th>
                <th>DNI</th>
                <th>Producto</th>
                <th>Cantidad</th>
                <th>Valor</th>
                <th>Pagado</th>
                <th>Debe</th>
                <th>Ruta carpeta</th>
                <th>Usuario</th>
                @if (Model.CanEdit)
                {
                    <th></th>
                }
                @if (Model.CanViewAudit)
                {
                    <th></th>
                }
            </tr>
        </thead>
        <tbody>
        @if (Model.Records.Count == 0)
        {
            <tr>
                <td colspan="@totalCols" class="text-center text-muted">No hay registros.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.Records)
            {
                <tr>
                    <td><span class="badge text-bg-@item.StatusCatalog.BadgeClass">@item.StatusCatalog.Name</span></td>
                    <td>@item.RecordDate.ToString("yyyy-MM-dd")</td>
                    <td>@item.Cellphone</td>
                    <td>@item.NameOrReference</td>
                    <td>@item.CallActivity</td>
                    <td>@item.Dni</td>
                    <td>@item.Product?.Name</td>
                    <td>@item.Quantity</td>
                    <td>@($"S/ {item.ProductAmount:0.00}")</td>
                    <td>@($"S/ {item.PaidAmount:0.00}")</td>
                    <td>@($"S/ {item.BalanceDue:0.00}")</td>
                    <td>@item.FolderPath</td>
                    <td>@item.CreatedByUserName</td>
                    @if (Model.CanEdit)
                    {
                        <td class="text-nowrap">
                            <a asp-page="/Records/Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                        </td>
                    }
                    @if (Model.CanViewAudit)
                    {
                        <td class="text-center">
                            <button type="button"
                                    class="btn btn-sm btn-outline-secondary btn-audit"
                                    data-id="@item.Id"
                                    data-celular="@item.Cellphone"
                                    title="Ver historial de cambios">
                                ??
                            </button>
                        </td>
                    }
                </tr>
            }
        }
        </tbody>
    </table>
</div>

@if (Model.CanViewAudit)
{
    <!-- Modal Auditoría -->
    <div class="modal fade" id="auditModal" tabindex="-1" aria-labelledby="auditModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="auditModalLabel">Historial de cambios</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="auditModalBody">
                    <div class="text-center py-3">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.querySelectorAll('.btn-audit').forEach(btn => {
            btn.addEventListener('click', async () => {
                const id = btn.dataset.id;
                const celular = btn.dataset.celular;

                document.getElementById('auditModalLabel').textContent = `Historial · Celular: ${celular}`;
                document.getElementById('auditModalBody').innerHTML =
                    '<div class="text-center py-3"><div class="spinner-border text-primary" role="status"></div></div>';

                const modal = new bootstrap.Modal(document.getElementById('auditModal'));
                modal.show();

                try {
                    const resp = await fetch(`/Records/Index?handler=Audit&id=${id}`);
                    const logs = await resp.json();
                    renderAudit(logs);
                } catch {
                    document.getElementById('auditModalBody').innerHTML =
                        '<div class="alert alert-danger">Error al cargar el historial.</div>';
                }
            });
        });

        function renderAudit(logs) {
            const body = document.getElementById('auditModalBody');

            if (!logs || logs.length === 0) {
                body.innerHTML = '<p class="text-muted text-center">Sin historial de cambios para este registro.</p>';
                return;
            }

            let html = '';
            for (const log of logs) {
                const badgeColor = log.action === 'Creado' ? 'success' : 'warning';
                html += `
                    <div class="border rounded p-3 mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>
                                <span class="badge text-bg-${badgeColor} me-2">${log.action}</span>
                                <strong>${log.changedByUserName}</strong>
                            </span>
                            <span class="text-muted small">${log.changedAt}</span>
                        </div>
                        ${renderDetails(log.details)}
                    </div>`;
            }

            body.innerHTML = html;
        }

        function renderDetails(details) {
            if (!details) return '';

            try {
                const data = JSON.parse(details);

                if (typeof data !== 'object' || Array.isArray(data)) {
                    return `<pre class="bg-light p-2 rounded small">${JSON.stringify(data, null, 2)}</pre>`;
                }

                let rows = '';
                for (const [key, value] of Object.entries(data)) {
                    rows += `<tr><td class="fw-semibold text-nowrap">${key}</td><td>${value ?? ''}</td></tr>`;
                }

                return `<table class="table table-sm table-bordered mb-0"><tbody>${rows}</tbody></table>`;
            } catch {
                return `<pre class="bg-light p-2 rounded small">${details}</pre>`;
            }
        }
    </script>
}
